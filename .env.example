# === Application ===
NODE_ENV=production
PORT=3500
API_KEY=your-local-api-key-here

# === SQL Server (Sage Bijou — source) ===
MSSQL_HOST=host.docker.internal
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=your-password
MSSQL_DATABASE=your-sage-database

# === API-VPS (cible distante) ===
VPS_API_URL=https://your-vps-domain.com/sync
SYNC_API_KEY=your-sync-api-key-64-chars-minimum
SYNC_HMAC_SECRET=your-hmac-secret
SYNC_HMAC_ENABLED=false
SYNC_TIMEOUT=30000
SYNC_BATCH_SIZE=100

# === Synchronisation ===
SYNC_INCREMENTAL_INTERVAL=2
SYNC_FULL_INTERVAL=60
QUEUE_PROCESS_INTERVAL=30
HEALTHCHECK_INTERVAL=30

# === Alertes ===
ALERT_CHECK_INTERVAL=60
ALERT_QUEUE_WARNING=1000
ALERT_QUEUE_CRITICAL=5000
ALERT_SYNC_LATENCY_MAX=60

# === Metriques ===
METRICS_ENABLED=true
METRICS_ALLOWED_IPS=127.0.0.1,::1,prometheus

# === Grafana ===
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-grafana-password

# === CORS ===
CORS_ORIGINS=http://localhost:3000
