# === Application ===
NODE_ENV=production
PORT=3500
API_KEY=your-local-api-key-here

# === SQL Server (Sage Bijou — source) ===
# Depuis un conteneur sur la VM CentOS, le serveur Sage doit être joignable
# par DNS/IP. Utiliser host.docker.internal seulement si Sage tourne sur
# le même hôte Docker (avec extra_hosts: host.docker.internal:host-gateway).
MSSQL_HOST=your-sage-host
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=your-password
MSSQL_DATABASE=your-sage-database

# === API-VPS (cible distante) ===
# URL publique HTTPS du VPS qui héberge l'API-ONLINE.
VPS_API_URL=https://your-vps-domain.com/api/v1/sync
SYNC_API_KEY=your-sync-api-key-64-chars-minimum
SYNC_HMAC_SECRET=your-hmac-secret
SYNC_HMAC_ENABLED=false

# Timeouts genereux pour reseau lent/instable
SYNC_TIMEOUT=60000
SYNC_BATCH_SIZE=50

# Retry avec backoff exponentiel sur erreurs reseau/5xx
SYNC_RETRY_MAX=3
SYNC_RETRY_BASE_DELAY=2000

# Fiabilite full sync de masse (milliers d'enregistrements)
# Taille des pages de lecture Sage (OFFSET/FETCH) : borne le pic memoire.
SYNC_READ_PAGE_SIZE=500
# Taille des lots d'IDs actifs envoyes a /receive/deletions et /check
# (evite un WHERE NOT IN (...) massif cote PostgreSQL).
SYNC_DELETIONS_CHUNK=1000

# === Synchronisation ===
SYNC_INCREMENTAL_INTERVAL=5
SYNC_FULL_INTERVAL=180
QUEUE_PROCESS_INTERVAL=60
HEALTHCHECK_INTERVAL=60
HEALTHCHECK_BACKOFF_MAX=300

# Date a partir de laquelle on recupere les donnees Sage Compta (YYYY-MM-DD).
# - Factures : DO_Date >= SYNC_START_DATE
# - Reglements : RG_Date >= SYNC_START_DATE
# - Articles eligibles : factures dont DO_Date >= SYNC_START_DATE
# Vide = pas de borne (recupere tout l'historique).
SYNC_START_DATE=2025-01-01

# TTL (en secondes) du cache des AR_Ref vendus aux commerciaux.
# La jointure F_DOCLIGNE x F_DOCENTETE x F_COMPTET ne tourne qu'une fois par TTL.
SYNC_ARTICLE_CACHE_TTL=600

# Circuit breaker
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN=300

# === Alertes ===
ALERT_CHECK_INTERVAL=120
ALERT_QUEUE_WARNING=1000
ALERT_QUEUE_CRITICAL=5000
ALERT_SYNC_LATENCY_MAX=600

# === Metriques ===
METRICS_ENABLED=true
METRICS_ALLOWED_IPS=127.0.0.1,::1,172.16,172.17,172.18,172.19,172.20,172.21,10.0

# === Grafana ===
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-grafana-password

# === CORS ===
CORS_ORIGINS=http://localhost:3000
